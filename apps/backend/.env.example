# ================================
# Rentel Backend — Environment Config
# ================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---- App ----
NODE_ENV=development
PORT=8000
API_VERSION=v1
APP_NAME=Rentel API
LOG_LEVEL=debug

# ---- Database (Supabase PostgreSQL) ----
# Get from Supabase → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ---- Supabase ----
# Get from Supabase → Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
# IMPORTANT: Service role key has full DB bypass — NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- JWT (generate with: openssl rand -hex 64) ----
JWT_ACCESS_SECRET=change_this_to_a_very_long_random_secret_minimum_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_minimum_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- Redis ----
# Local dev: redis://localhost:6379
# Production: your Redis provider URL
REDIS_URL=redis://localhost:6379

# ---- Email (Resend) ----
# Get API key from resend.com
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@rentel.com
FROM_NAME=Rentel

# ---- Supabase Storage ----
STORAGE_BUCKET_IMAGES=property-images
STORAGE_BUCKET_VIDEOS=property-videos
STORAGE_BUCKET_AVATARS=avatars

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_GLOBAL=100
RATE_LIMIT_MAX_AUTH=10

# ---- App URLs (for email links) ----
CLIENT_WEB_URL=http://localhost:3000
CLIENT_MOBILE_SCHEME=rentel://

# ---- File Upload Limits ----
MAX_FILE_SIZE_MB=10
MAX_IMAGE_COUNT=10
MAX_VIDEO_COUNT=3

# ---- Bcrypt ----
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
