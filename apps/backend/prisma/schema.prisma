model NotifyTemplate {
  id                 Int           @id @default(autoincrement()) @map("TemplateID")
  code               String        @unique @map("TemplateCode") @db.VarChar(100)
  name               String        @map("TemplateName") @db.VarChar(200)
  subject            String?       @map("Subject") @db.VarChar(500)
  body_html          String?       @map("BodyHTML")
  body_text          String?       @map("BodyText")
  supported_channels String        @default("Email,SMS,Push,InApp") @map("SupportedChannels") @db.VarChar(100)
  variables          String?       @map("Variables")
  is_active          Boolean       @default(true) @map("IsActive")
  created_date       DateTime      @default(now()) @map("CreatedDate")

  queue              NotifyQueue[]

  @@map("notify_templates")
}

model NotifyQueue {
  id            BigInt         @id @default(autoincrement()) @map("NotificationID")
  user_id       BigInt         @map("UserID")
  template_id   Int            @map("TemplateID")
  channel       String         @map("Channel") @db.VarChar(20)
  recipient     String         @map("Recipient") @db.VarChar(500)
  data          String?        @map("Data")
  status        String         @default("Pending") @map("Status") @db.VarChar(20)
