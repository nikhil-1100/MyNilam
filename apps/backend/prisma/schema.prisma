  created_date      DateTime      @default(now()) @map("CreatedDate")

  campaign          AdCampaign    @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  analytics         AdAnalytic[]

  @@index([is_active])
  @@map("ad_banners")
}

model AdAnalytic {
  id          BigInt   @id @default(autoincrement()) @map("AdAnalyticID")
  banner_id   BigInt   @map("BannerID")
  event_date  DateTime @map("EventDate") @db.Date
  impressions Int      @default(0) @map("Impressions")
  clicks      Int      @default(0) @map("Clicks")
