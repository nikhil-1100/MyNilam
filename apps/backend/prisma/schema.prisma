  listing_id   BigInt      @map("ListingID")
  user_id      BigInt?     @map("UserID")
  ip_address   String?     @map("IPAddress") @db.VarChar(45)
  user_agent   String?     @map("UserAgent") @db.VarChar(500)
  referrer_url String?     @map("ReferrerURL") @db.VarChar(2000)
  viewed_date  DateTime    @default(now()) @map("ViewedDate")

  listing      ListListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  user         AuthUser?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([listing_id, viewed_date])
  @@index([viewed_date])
  @@map("anlyt_listing_views")
}

model Hostel {
  id                 BigInt     @id @default(autoincrement()) @map("HostelID")
  property_id        BigInt     @unique @map("PropertyID")
  name               String     @map("Name") @db.VarChar(200)
  total_bed_spaces   Int        @map("TotalBedSpaces")
  total_rooms        Int        @map("TotalRooms")
  bathroom_count     Int        @map("BathroomCount")
  attached_bathrooms Boolean    @default(false) @map("AttachedBathrooms")
  gender_type        String     @default("UNISEX") @map("GenderType") @db.VarChar(50)

  // Amenities
  wifi_enabled    Boolean @default(false) @map("WifiEnabled")
  wifi_speed      String? @map("WifiSpeed") @db.VarChar(100)
  hot_water       Boolean @default(false) @map("HotWater")
  water_filter    Boolean @default(false) @map("WaterFilter")
  mess_food       Boolean @default(false) @map("MessFood")
  laundry_enabled Boolean @default(false) @map("LaundryEnabled")
  ac_available    Boolean @default(false) @map("AcAvailable")
  water_source    String? @map("WaterSource") @db.VarChar(100)

  // Vacancy
  vacant_beds      Int      @default(0) @map("VacantBeds")
  vacant_rooms     Int      @default(0) @map("VacantRooms")
  vacant_sharings  String[] @map("VacantSharings")
  allowed_sharings String[] @map("AllowedSharings")

  created_at DateTime @default(now()) @map("CreatedDate")
  updated_at DateTime @updatedAt @map("ModifiedDate")

  property ListListing @relation(fields: [property_id], references: [id], onDelete: Cascade)
  pricing  HostelPricing[]
  admins   AuthUser[] @relation("HostelAdmin")

  @@map("list_hostels")
}

model HostelPricing {
  id         BigInt           @id @default(autoincrement()) @map("PricingID")
  hostel_id  BigInt           @map("HostelID")
  share_type String           @map("ShareType") @db.VarChar(50)
  price      Int              @map("Price")
  created_at DateTime         @default(now()) @map("CreatedDate")
  updated_at DateTime         @updatedAt @map("ModifiedDate")

  hostel Hostel @relation(fields: [hostel_id], references: [id], onDelete: Cascade)

  @@unique([hostel_id, share_type])
  @@map("list_hostel_pricing")
}

// =============================================================================
// BACKWARD COMPATIBILITY MODELS (MAP TO NEW TABLE PREFIXES)
// =============================================================================

model Favorite {
  id          BigInt      @id @default(autoincrement()) @map("WishlistID")
  user_id     BigInt      @map("UserID")
  property_id BigInt      @map("ListingID")
  created_at  DateTime    @default(now()) @map("CreatedDate")

  user        AuthUser    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  property    ListListing @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@unique([user_id, property_id])
  @@map("wish_wishlist")
}

model Message {
  id              BigInt      @id @default(autoincrement()) @map("MessageID")
  conversation_id BigInt      @map("ConversationID")
  sender_user_id  BigInt      @map("SenderUserID")
  content         String?     @map("MessageContent")
  attachment_url  String?     @map("AttachmentURL") @db.VarChar(2000)
  attachment_type String?     @map("AttachmentType") @db.VarChar(50)
  sent_date       DateTime    @default(now()) @map("SentDate")
  read_date       DateTime?   @map("ReadDate")
  is_edited       Boolean     @default(false) @map("IsEdited")
  is_deleted      Boolean     @default(false) @map("IsDeleted")

  conversation    ChatConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          AuthUser    @relation(fields: [sender_user_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, sent_date])
  @@map("chat_messages")
}

model Review {
  id                   BigInt      @id @default(autoincrement()) @map("ReviewID")
  reviewed_by_user_id  BigInt      @map("ReviewedByUserID")
  reviewed_entity_type String      @map("ReviewedEntityType") @db.VarChar(20)
  reviewed_entity_id   BigInt      @map("ReviewedEntityID")
  listing_id           BigInt?     @map("ListingID")
  rating               Int         @map("Rating") @db.SmallInt
  comment              String?     @map("Comment") @db.VarChar(2000)
  is_verified          Boolean     @default(false) @map("IsVerified")
  is_active            Boolean     @default(true) @map("IsActive")
  created_date         DateTime    @default(now()) @map("CreatedDate")
  modified_date        DateTime?   @updatedAt @map("ModifiedDate")

  reviewer             AuthUser    @relation(fields: [reviewed_by_user_id], references: [id], onDelete: Cascade)
  listing              ListListing? @relation(fields: [listing_id], references: [id], onDelete: SetNull)

  @@index([reviewed_entity_type, reviewed_entity_id])
  @@map("review_reviews")
}

model Inquiry {
  id           BigInt      @id @default(autoincrement()) @map("InquiryID")
  user_id      BigInt      @map("UserID")
  property_id  BigInt      @map("ListingID")
  message      String      @map("Message")
  status       String      @default("PENDING") @map("Status") @db.VarChar(20)
  response     String?     @map("Response")
  responded_by BigInt?     @map("RespondedBy")
  responded_at DateTime?   @map("RespondedAt")
  created_at   DateTime    @default(now()) @map("CreatedDate")
  updated_at   DateTime    @updatedAt @map("ModifiedDate")

  user         AuthUser    @relation("InquiryUser", fields: [user_id], references: [id], onDelete: Cascade)
  responder    AuthUser?   @relation("InquiryResponder", fields: [responded_by], references: [id], onDelete: SetNull)
  property     ListListing @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@index([property_id])
  @@index([user_id])
  @@index([status])
  @@map("list_inquiries")
}

model Visit {
  id           BigInt      @id @default(autoincrement()) @map("VisitID")
  user_id      BigInt      @map("UserID")
  property_id  BigInt      @map("ListingID")
  scheduled_at DateTime    @map("ScheduledAt")
  status       String      @default("REQUESTED") @map("Status") @db.VarChar(20)
  notes        String?     @map("Notes")
  owner_notes  String?     @map("OwnerNotes")
  created_at   DateTime    @default(now()) @map("CreatedDate")
  updated_at   DateTime    @updatedAt @map("ModifiedDate")

  user         AuthUser    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  property     ListListing @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@map("list_visits")
}

model Notification {
  id         BigInt   @id @default(autoincrement()) @map("NotificationID")
  user_id    BigInt   @map("UserID")
  type       String   @map("Type") @db.VarChar(50)
  title      String   @map("Title") @db.VarChar(200)
  message    String   @map("Message")
  read       Boolean  @default(false) @map("Read")
  created_at DateTime @default(now()) @map("CreatedDate")

  user       AuthUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notify_notifications")
}

model SearchHistory {
  id         BigInt   @id @default(autoincrement()) @map("SearchHistoryID")
  user_id    BigInt   @map("UserID")
  query      String   @map("Query") @db.VarChar(500)
  created_at DateTime @default(now()) @map("CreatedDate")

  user       AuthUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("wish_search_history")
}
