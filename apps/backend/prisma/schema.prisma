  messages             Message[]

  @@index([subject_entity_type, subject_entity_id])
  @@map("chat_conversations")
}

model ChatConversationParticipant {
  id              BigInt           @id @default(autoincrement()) @map("ParticipantID")
  conversation_id BigInt           @map("ConversationID")
  user_id         BigInt           @map("UserID")
  last_read_date  DateTime?        @map("LastReadDate")
  is_muted        Boolean          @default(false) @map("IsMuted")
  joined_date     DateTime         @default(now()) @map("JoinedDate")

  conversation    ChatConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user            AuthUser         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([conversation_id, user_id])
  @@map("chat_conversation_participants")
}

