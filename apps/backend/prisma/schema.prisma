}

model NotifyPreference {
  id                BigInt   @id @default(autoincrement()) @map("PreferenceID")
  user_id           BigInt   @map("UserID")
  notification_type String   @map("NotificationType") @db.VarChar(50)
  channel           String   @map("Channel") @db.VarChar(20)
