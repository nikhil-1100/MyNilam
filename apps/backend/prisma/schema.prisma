}

model ServServiceRequest {
  id              BigInt         @id @default(autoincrement()) @map("ServiceRequestID")
  user_id         BigInt         @map("UserID")
  service_id      Int            @map("ServiceID")
  listing_id      BigInt?        @map("ListingID")
  requested_price Decimal        @map("RequestedPrice") @db.Decimal(18, 2)
  status          String         @default("Pending") @map("Status") @db.VarChar(20)
  request_data    String?        @map("RequestData")
  assigned_to     BigInt?        @map("AssignedTo")
  completed_date  DateTime?      @map("CompletedDate")
  transaction_id  BigInt?        @map("TransactionID")
  created_date    DateTime       @default(now()) @map("CreatedDate")

  user            AuthUser       @relation("ServiceCustomers", fields: [user_id], references: [id], onDelete: Cascade)
  staff           AuthUser?      @relation("ServiceStaff", fields: [assigned_to], references: [id], onDelete: SetNull)
  service         ServService    @relation(fields: [service_id], references: [id])
  listing         ListListing?   @relation(fields: [listing_id], references: [id], onDelete: SetNull)
  transaction     PayTransaction? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("serv_service_requests")
}

// =============================================================================
// SCHEMA 14: [Chat] - Chat Module
// =============================================================================

model ChatConversation {
  id                   BigInt                        @id @default(autoincrement()) @map("ConversationID")
  guid                 String                        @unique @default(uuid()) @map("ConversationGUID") @db.Uuid
  subject_entity_type  String                        @map("SubjectEntityType") @db.VarChar(50)
  subject_entity_id    BigInt                        @map("SubjectEntityID")
  initiated_by         BigInt                        @map("InitiatedBy")
  last_message_date    DateTime?                     @map("LastMessageDate")
  last_message_preview String?                       @map("LastMessagePreview") @db.VarChar(200)
  message_count        Int                           @default(0) @map("MessageCount")
  is_active            Boolean                       @default(true) @map("IsActive")
  created_date         DateTime                      @default(now()) @map("CreatedDate")

  initiator            AuthUser                      @relation(fields: [initiated_by], references: [id], onDelete: Cascade)
