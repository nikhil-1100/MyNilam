model FraudReport {
  id                 BigInt          @id @default(autoincrement()) @map("ReportID")
  reported_by_user_id BigInt          @map("ReportedByUserID")
  target_entity_type String          @map("TargetEntityType") @db.VarChar(20)
  target_entity_id   BigInt          @map("TargetEntityID")
  report_reason      String          @map("ReportReason") @db.VarChar(50)
  description        String?         @map("Description") @db.VarChar(2000)
  evidence_urls      String?         @map("EvidenceURLs")
  status             String          @default("Open") @map("Status") @db.VarChar(20)
  reviewed_by        BigInt?         @map("ReviewedBy")
  resolution         String?         @map("Resolution") @db.VarChar(1000)
