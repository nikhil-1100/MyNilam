model ServServiceCategory {
  id          Int           @id @default(autoincrement()) @map("ServiceCategoryID")
  code        String        @unique @map("CategoryCode") @db.VarChar(50)
  name        String        @map("CategoryName") @db.VarChar(100)
  description String?       @map("Description") @db.VarChar(500)
  is_active   Boolean       @default(true) @map("IsActive")

  services    ServService[]

  @@map("serv_service_categories")
}

model ServService {
  id                  Int                 @id @default(autoincrement()) @map("ServiceID")
  service_category_id Int                 @map("ServiceCategoryID")
  code                String              @unique @map("ServiceCode") @db.VarChar(50)
  name                String              @map("ServiceName") @db.VarChar(200)
  description         String?             @map("Description")
  base_price          Decimal             @map("BasePrice") @db.Decimal(18, 2)
  currency            String              @default("USD") @map("Currency") @db.Char(3)
  is_active           Boolean             @default(true) @map("IsActive")
  created_date        DateTime            @default(now()) @map("CreatedDate")

  category            ServServiceCategory @relation(fields: [service_category_id], references: [id], onDelete: Cascade)
