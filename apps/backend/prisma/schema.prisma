  name              String        @map("BannerName") @db.VarChar(200)
  placement         String        @map("Placement") @db.VarChar(50)
  image_url         String        @map("ImageURL") @db.VarChar(2000)
  target_url        String?       @map("TargetURL") @db.VarChar(2000)
  alt_text          String?       @map("AltText") @db.VarChar(500)
  priority          Int           @default(0) @map("Priority")
  total_clicks      BigInt        @default(0) @map("TotalClicks")
  total_impressions BigInt        @default(0) @map("TotalImpressions")
