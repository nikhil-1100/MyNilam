  total_views        Int      @default(0) @map("TotalViews")
  total_inquiries    Int      @default(0) @map("TotalInquiries")
  revenue            Decimal  @default(0.00) @map("Revenue") @db.Decimal(18, 2)
  new_subscriptions  Int      @default(0) @map("NewSubscriptions")
